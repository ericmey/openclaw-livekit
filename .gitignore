# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.venv/
.pytest_cache/
.ruff_cache/

# Editor / OS
.DS_Store
.vscode/
.idea/
*.swp

# Secrets — these should never be in git
*.env
*.local.yaml
*.local.json
secrets/

# Real config files (filled in locally; .example templates stay tracked).
# Matches e.g. config/livekit.yaml but NOT config/livekit.yaml.example.
config/*.yaml
config/sip-*.json

# Voice logs — written at runtime.
logs/
