# Docker Compose for local livekit-sip + Redis.
#
# Assumes `livekit-server` is running separately (either native or in its
# own compose file). If you want everything dockerized, add a livekit
# service block below — reference:
# https://github.com/livekit/sip/blob/main/docker-compose.yaml
#
# Start with:
#   docker compose -f docker-compose.yaml.example up
#
# Stop with:
#   docker compose -f docker-compose.yaml.example down

services:
  redis:
    image: redis:7-alpine
    container_name: openclaw-redis
    ports:
      - "127.0.0.1:6379:6379"
    restart: unless-stopped
    command: ["redis-server", "--save", "", "--appendonly", "no"]
    # Redis state is ephemeral. livekit-sip only needs it for live
    # session tracking; losing it just means any in-flight call drops.

  livekit-sip:
    # Pinned. Bump deliberately (verify against release notes + rerun a
    # full inbound call) — never let `:latest` drift in on its own.
    image: livekit/sip:v1.2.0
    container_name: openclaw-livekit-sip
    depends_on:
      - redis
    # Host networking is required for SIP — the service needs to
    # advertise the host's real IP in SDP, and RTP traffic on
    # 10000-20000/udp can't be easily port-mapped in bridge mode.
    network_mode: host
    restart: unless-stopped
    volumes:
      # Mount your real config file (NOT the .example version).
      - ~/.openclaw/config/livekit-sip.yaml:/config.yaml:ro
    command: ["--config", "/config.yaml"]
    environment:
      # Optional: override ws_url without editing the config file.
      # LIVEKIT_URL: "ws://host.docker.internal:7880"  # macOS
      # LIVEKIT_URL: "ws://172.17.0.1:7880"            # Linux
