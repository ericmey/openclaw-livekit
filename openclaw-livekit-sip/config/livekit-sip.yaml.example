# livekit-sip configuration template.
#
# Copy to ~/.openclaw/config/livekit-sip.yaml and fill in real values.
# Never commit the filled-in version — *.local.yaml is gitignored.
#
# Docs: https://docs.livekit.io/transport/self-hosting/sip-server/

# ---- Logging ----------------------------------------------------------
# debug | info | warn | error. Use debug for first setup, then drop to info.
log_level: info

# ---- LiveKit server credentials --------------------------------------
# Same key/secret pair livekit-server is using. For a local dev box:
#   api_key: devkey
#   api_secret: secret
api_key: "REPLACE_ME_LIVEKIT_API_KEY"
api_secret: "REPLACE_ME_LIVEKIT_API_SECRET"

# WebSocket URL of the LiveKit server. Local dev:
#   ws://127.0.0.1:7880
# Self-hosted (via reverse proxy):
#   wss://livekit.example.com
ws_url: "ws://127.0.0.1:7880"

# ---- Redis (REQUIRED) ------------------------------------------------
# livekit-sip uses Redis for SIP session state. No in-memory fallback.
redis:
  address: "127.0.0.1:6379"
  # username: ""         # uncomment if using Redis ACLs
  # password: ""
  # db: 0

# ---- SIP listener ----------------------------------------------------
# Default SIP signaling port. Needs to be reachable from Twilio's SBC
# (inbound) and from this host to Twilio's termination URI (outbound).
sip_port: 5060

# UDP range for RTP media. 10000 ports is generous; the default is fine
# unless you're doing heavy concurrency.
rtp_port_range_start: 10000
rtp_port_range_size: 10000

# Set to true when running behind NAT where the SIP service needs to
# advertise its external IP in SDP. For a macOS home setup behind a
# router: probably true. For a VPS with a direct public IP: false.
use_external_ip: true

# Explicit external IP override. Leave commented to auto-detect via STUN.
# external_ip: "203.0.113.42"

# ---- Transport ------------------------------------------------------
# Twilio supports UDP, TCP, and TLS. TCP is a good default — more
# reliable than UDP for SIP signaling without the cert setup of TLS.
# For TLS, see https://docs.livekit.io/sip/secure-trunking/
# transport: tcp    # some versions of livekit-sip infer from origination URI

# ---- Attribute mapping ----------------------------------------------
# Optional: copy specific SIP headers onto the participant attributes
# dict that agents can read. Useful if Twilio passes a custom X-header.
# headers_to_attributes:
#   X-Twilio-Call-Sid: sip.h.x-twilio-call-sid
