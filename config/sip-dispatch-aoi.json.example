{
  "_comment": [
    "Dispatch rule for the phone-aoi agent. See sip-dispatch-nyla.json.example",
    "for the full field explanation and the numbers/inbound_numbers warning."
  ],

  "dispatch_rule": {
    "name": "twilio-to-phone-aoi",

    "numbers": [
      "+15550000002"
    ],

    "rule": {
      "dispatchRuleIndividual": {
        "roomPrefix": "phone"
      }
    },

    "room_config": {
      "agents": [
        {
          "agentName": "phone-aoi",
          "metadata": "{\"route\":\"default\",\"source\":\"sip\"}"
        }
      ]
    }
  }
}
