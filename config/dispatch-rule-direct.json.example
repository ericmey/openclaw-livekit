{
  "_comment": [
    "Dispatch rule template — single shared room, all callers join the same room.",
    "",
    "Use this when you want a 'party line' experience: multiple callers into",
    "one room, one agent handling them. Rarely what you want for normal",
    "phone support — prefer dispatch-rule-per-call.json.example for that.",
    "",
    "Apply with:",
    "  lk sip dispatch create config/dispatch-rule-direct.json --trunks <trunk-id>"
  ],

  "name": "twilio-party-room",

  "rule": {
    "dispatchRuleDirect": {
      "roomName": "phone-party-shared"
    }
  },

  "inbound_numbers": [
    "+15550000000"
  ],

  "roomConfig": {
    "agents": [
      {
        "agentName": "phone-party",
        "metadata": "{\"route\": \"party-line\", \"source\": \"sip\"}"
      }
    ]
  }
}
