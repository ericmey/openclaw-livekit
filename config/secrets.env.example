# OpenClaw LiveKit agent secrets — EXAMPLE / TEMPLATE.
#
# Copy to secrets/livekit-agents.env at the repo root (gitignored) and
# fill in real values. scripts/deploy-agents.sh reads from that path
# and renders per-agent launchd plists.
#
# Override location: OPENCLAW_SECRETS=/abs/path/to/file make deploy
#
# Rotation workflow:
#   1. Update value(s) in secrets/livekit-agents.env.
#   2. Re-run scripts/deploy-agents.sh — it re-renders the plists in
#      ~/Library/LaunchAgents/ and kickstarts each agent so the new
#      values take effect without a full reinstall.

# ---- LiveKit (shared by all agents) ----
# Must match livekit.yaml and livekit-sip.yaml.
LIVEKIT_URL=ws://127.0.0.1:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret-change-me-before-real-use

# ---- External APIs (shared) ----
# Google Gemini API key — realtime voice (nyla, aoi) and chained LLM (party).
GOOGLE_API_KEY=your-google-api-key-here

# ---- OpenClaw gateway auth (shared) ----
# Used by tools that call back into the gateway (memory, sessions, etc.).
GATEWAY_AUTH_TOKEN=your-gateway-token-here

# ---- Per-agent Discord bot tokens ----
# The deploy script maps each agent to DISCORD_BOT_TOKEN in its plist:
#   nyla  -> DISCORD_TOKEN_NYLA
#   aoi   -> DISCORD_TOKEN_AOI
#   party -> DISCORD_TOKEN_NYLA (reuses Nyla's token; party is the
#                                 chained-STT persona, not a separate bot)
DISCORD_TOKEN_NYLA=your-nyla-discord-bot-token
DISCORD_TOKEN_AOI=your-aoi-discord-bot-token
