# OpenClaw LiveKit agent secrets.
#
# Copy to ~/.openclaw/secrets/livekit-agents.env (the deploy script reads
# from that path). Keep the real copy OUT of git — ~/.openclaw/secrets/ is
# your local-only store.
#
# Rotation workflow:
#   1. Update the value(s) in your real ~/.openclaw/secrets/livekit-agents.env.
#   2. Re-run scripts/deploy-agents.sh — it re-renders the plists in
#      ~/Library/LaunchAgents/ and kickstarts each agent so the new values
#      take effect without a full reinstall.

# LiveKit server — must match livekit.yaml and livekit-sip.yaml.
LIVEKIT_URL=ws://127.0.0.1:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret-change-me-before-real-use

# Google Gemini API key for realtime voice (nyla, aoi) and chained
# pipeline LLM (party).
GOOGLE_API_KEY=your-google-api-key-here

# OpenClaw gateway token — used by tools that call back into the gateway
# (memory, sessions, etc.).
GATEWAY_AUTH_TOKEN=your-gateway-token-here
